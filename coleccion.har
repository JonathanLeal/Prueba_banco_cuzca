@baseUrl = http://localhost:8084
@token = <JWT_TOKEN>

### ==========================================================
### 1. Registrar usuario
### ==========================================================

POST {{baseUrl}}/api/v1/auth/register
Content-Type: application/json

{
  "firstName": "Jonathan",
  "lastName": "Leal",
  "email": "jo@jo.com",
  "password": "123",
  "role": "ADMIN"
}

### ==========================================================
### 2. Login
### ==========================================================

POST {{baseUrl}}/api/v1/auth/login
Content-Type: application/json

{
  "email": "jo@jo.com",
  "password": "123"
}

###
# Copiar el JWT obtenido y reemplazar @token

### ==========================================================
### 3. Crear espacio
### ==========================================================

POST {{baseUrl}}/api/v1/spaces
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Hermoso",
  "type": "DESK",
  "capacity": 10,
  "location": "Piso 1",
  "hourlyRate": 10.00
}

### ==========================================================
### 4. Obtener espacios
### ==========================================================

GET {{baseUrl}}/api/v1/spaces
Authorization: Bearer {{token}}

### ==========================================================
### 5. Crear reserva
### ==========================================================

POST {{baseUrl}}/api/reservations
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "spaceId": 10,
  "startTime": "2026-08-10T15:00:00",
  "endTime": "2026-08-10T16:00:00"
}

### ==========================================================
### 6. Reporte de ocupación
### ==========================================================

GET {{baseUrl}}/api/reports/occupancy?start=2026-08-01T00:00:00&end=2026-08-31T23:59:59
Authorization: Bearer {{token}}